{
  "name": "@baukalk/app",
  "version": "0.1.0",
  "private": true,
  "description": "BauKalk Pro Desktop-App (Electron + React)",
  "type": "module",
  "main": "dist-electron/main.js",
  "scripts": {
    "dev": "vite",
